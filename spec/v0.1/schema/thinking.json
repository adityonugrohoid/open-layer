{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openlayer.dev/schema/v0.1/thinking.json",
  "title": "Thinking",
  "description": "Thinking/reasoning token extensions for chat completion requests and responses.",
  "$defs": {
    "thinking_request": {
      "type": "object",
      "description": "Request parameters for enabling thinking/reasoning.",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to enable thinking/reasoning output."
        },
        "budget_tokens": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum tokens the model may use for thinking. Providers that do not support budget control accept and ignore this field."
        }
      },
      "additionalProperties": false
    },
    "thinking_response": {
      "type": "object",
      "description": "Thinking content in an assistant message response.",
      "required": ["content"],
      "properties": {
        "content": {
          "type": "string",
          "description": "The model's thinking/reasoning text."
        }
      },
      "additionalProperties": false
    }
  }
}
